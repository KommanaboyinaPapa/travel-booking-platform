# ──────────────────────────────────────────────
# Travel Booking Platform — Backend Configuration
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# For Render: set these in Dashboard → Environment Variables.

# Server
PORT=5000
NODE_ENV=production

# ── Database (MySQL / Cloud SQL) ──────────────
# For local dev: DB_HOST=localhost, DB_PORT=3306
# For Render: use your cloud MySQL connection string values
DB_HOST=your-cloud-mysql-host.amazonaws.com
DB_PORT=3306
DB_NAME=travel_booking_db
DB_USER=your_db_user
DB_PASSWORD=your_secure_db_password

# ── Authentication ────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace_with_a_strong_random_secret

# ── CORS ──────────────────────────────────────
# Comma-separated list of allowed origins.
# For local dev: CORS_ORIGIN=*
# For production: CORS_ORIGIN=https://your-frontend.vercel.app
CORS_ORIGIN=*
